<?xml version="1.0" encoding="utf-8" ?>
<!--
  ============================================================================
  DO NOT EDIT THIS FILE
  ============================================================================
  This file is a COLD-START FALLBACK ONLY. Edits made here are IGNORED at
  runtime as soon as HemoScope can reach the cloud config repo.

  Edit the live version in:
      https://github.com/LiteBC/Hemoscope-config

  Commit and push there. The bench picks up the change at the next launch
  (look for [ConfigSync] lines in HemoScope.log).

  This bundled copy exists only so the app can still boot when:
    - it is a fresh install with no local cache yet, AND
    - the cloud repo is unreachable (offline / GitHub down).
  ============================================================================
-->
<appSettings>
	<add key="Version.Hardware" value="VB3002" />

	<!-- Astro 1-->
	<add key="BacklightDeviceAstroPort" value="2" />
	<add key="LineCamDeviceAstroPort" value="1" />
	<add key="MotorDeviceAstroPort" value="4" />
	<add key="RotationDeviceAstroPort" value="5" />

	<!-- Astro 2-->
	<add key="WideCamDeviceAstroPort" value="-1" />

	<add key="WideCamera.BaslerUsb.Aperture" value="5.6" />
	<add key="WideCamera.BaslerCxp.Aperture" value="5.6" />
	<add key="BacklightDevice" value="Dummy" />
	<add key="BacklightWavelengths" value="{1:452,2:525,3:417,4:641}" />
	<add key="MainLed" value="1" />
	<add key="Global.LinePixelSize" value="0.1121e-3" />
	<add key="LineCamera.PixelSlope" value="-0.0000161e-3" />
	<add key="Global.MaxSpeed" value="20" />
	<add key="WideCamera.PixelSize" value="0.91e-3" />
	<add key="WideCamera.MotorCoordinateMatrix" value="[[0.999785032, -0.032133408], [0.0227500, 1.000258748]]"/>
	<add key="LineCamDevice" value="Dummy" />
	<add key="LineInWideCalibration" value="{cx:585.11,cy:433.47,r:11.47,a:9.00,angle:11}" />
	<add key="MotorDevice" value="Dummy" />
	<add key="RotationDevice" value="Dummy" />
	<add key="WaterSensor.Threshold" value="1000" />
	<add key="WideCamDevice0" value="Dummy" />
	<add key="WideCamDevice0.TriggerPin" value="7" />
	<add key="WideCamDevice1" value="Dummy" />
	<add key="WideCamDevice1.TriggerPin" value="8" />
	<add key="LensDevice" value="Dummy" />

	<!-- Motor range -->
	<add key="X.Minimum" value="0" />
	<add key="X.Maximum" value="5" />
	<add key="X.Polarity" value="1" />
	<add key="X.Parking" value="4" />
	<add key="X.StepSize" value="0.1" />
	<add key="Y.Minimum" value="0" />
	<add key="Y.Maximum" value="5" />
	<add key="Y.Polarity" value="-1" />
	<add key="Y.Parking" value="1" />
	<add key="Y.StepSize" value="0.1" />
	<add key="Z.Minimum" value="6.5" />
	<add key="Z.Maximum" value="8.5" />
	<add key="Z.Polarity" value="1" />
	<add key="Z.StepSize" value="0.1" />
	<add key="Global.StartZ" value="6.5" />

	<!-- Imaging parameters -->
	<add key="LineCamera.Height" value="1000" />
	<add key="LineCamera.OffsetX" value="410" />
	<add key="LineCamera.OffsetY" value="0" />
	<add key="LineCamera.Width" value="1280" />
	<add key="ROI.Height" value="1216" />
	<add key="ROI.OffsetX" value="0" />
	<add key="ROI.OffsetY" value="0" />
	<add key="ROI.Width" value="1368" />

	<add key="SystemPreparation.dryMinimumPeakMedianIntensityThreshold" value="0.9" />
	<add key="SystemPreparation.WetMinimumLeftPeakMedianIntensityThreshold" value="500" />
	<add key="SystemPreparation.WetMinimumRightPeakMedianIntensityThreshold" value="10" />
	<add key="WaterDetection.minimumLeftPeakMedianIntensityThreshold" value="300" />
	<add key="WaterDetection.minimumRightPeakMedianIntensityThreshold" value="10" />
	<add key="waterDetectionIntervalLength" value="0.8" />
	<add key="SpaceMouse.Enabled" value="TRUE" />
	<add key="SpaceMouse.FocusSensitivity" value="10000" />
	<add key="SpaceMouse.StageSensitivity" value="3000" />

	<add key="LedController.Device" value="Dummy" />

	<add key="WideCamera.Arduino.PinRoles" value='{"CXP":{"camera_pin":12,"led_groups":[[1,2,3]]},"USB":{"camera_pin":11,"led_groups":[[5],[6]]}}' />

</appSettings>
