<?xml version="1.0" encoding="utf-8" ?>
<appSettings>
	<add key="AppMode" value="Normal" />
	<add key="Interface" value="! 10k" />
	<add key="MassAutoScanSequence.DisableLipCheck" value="TRUE" />
	<!--<add key="BarcodeScannerFilter" value="VID_05E0&amp;PID_1200" />-->
	<add key="BarcodeScannerFilter" value="VID_0581&amp;PID_011A&amp;MI_00" />
	<add key="DeploymentSite" value="Lab" />

	<add key="DiskSpace.MinFreeGB" value="1500" />

	<add key="Python.LogLevel" value="Debug" />
	<add key="Python.SaveMode" value="Nothing" />
	<add key="Python.UseWarmUp" value="True" />

	<!--
		Operators vs. Patients (two separate concepts):
		  - Operator = the person who runs the test (clicks the Start button, etc.).
		  - Patient  = the test subject whose lip is attached to the device.
		In the lab the same employees play both roles, so the two lists are identical here.
		In production (10K) patients come from the barcode scanner and are NOT listed in config.
	-->
	<add key="OperatorNames" value="BarryLoevsky,DanielItkes,DavidSolomon,EinavShmueli,EliavEpstein,HenAlpern,JacobMinsky,MattiasMarder,MoriyaLeopold,OlegPetukhov,OrPeleg,RakefetRozen,TomerGrinberg,YairVagshal" />
	<add key="PatientNames"  value="BarryLoevsky,DanielItkes,DavidSolomon,EinavShmueli,EliavEpstein,HenAlpern,JacobMinsky,MattiasMarder,MoriyaLeopold,OlegPetukhov,OrPeleg,RakefetRozen,TomerGrinberg,YairVagshal" />
</appSettings>
