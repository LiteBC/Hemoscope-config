<?xml version="1.0" encoding="utf-8" ?>
<appSettings>
	<add key="AppMode" value="Normal" />
	<add key="Interface" value="10k" />
	<add key="MassAutoScanSequence.DisableLipCheck" value="TRUE" />
	<add key="BarcodeScannerFilter" value="VID_27DD&amp;PID_0103" />

	<add key="DiskSpace.MinFreeGB" value="50" />

<!-- TODO!!-->
	<add key="DeploymentSite" value="10K" />

	<add key="Python.LogLevel" value="Debug" />
	<add key="Python.SaveMode" value="OnError" />
	<add key="Python.UseWarmUp" value="True" />

	<!--
		Operator names shown in the 10K screen dropdown (comma-separated).
		Operator = the clinic staff member running the test.
		Note: Patient names are NOT configured here — in 10K the patient is identified
		by the barcode scanner, not by selection from a list.
	-->
	<add key="OperatorNames" value="Zehava,Ella,Yana,Anna,Lisa" />
</appSettings>
